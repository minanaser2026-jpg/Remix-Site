# ─────────────────────────────────────────────
# Railway Environment Variables
# Copy these into Railway → Service → Variables
# ─────────────────────────────────────────────

# ── مطلوب (Required) ──────────────────────────

# بيئة التشغيل - لازم تبقى production على Railway
NODE_ENV=production

# سر التشفير للـ sessions - أي string عشوائي طويل لا تغيره بعد كده
SESSION_SECRET=CHANGE_ME_TO_RANDOM_32_CHAR_STRING

# رابط قاعدة البيانات من Supabase
# Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── تلقائي (Auto-set by Railway) ─────────────
# Railway بيحطها تلقائي - متحطهاش إنت
# PORT=3000

# ── اختياري (Optional) ───────────────────────

# لو عندك دومين مخصص غير railway.app أضفه هنا (فاصل بفاصلة)
# ALLOWED_ORIGINS=https://yourdomain.com,https://another.com

# لو عايز تربط Facebook Reels
# FACEBOOK_PAGE_ACCESS_TOKEN=your_token_here
# FACEBOOK_PAGE_ID=your_page_id_here

# ── لا تحتاجها على Railway ───────────────────
# دي بس للـ Netlify serverless functions
# AWS_LAMBDA_FUNCTION_NAME=  (Railway مش Netlify)

# مسار الفرونتاند - Railway بيحسبه تلقائي من الكود
# FRONTEND_DIR=artifacts/remix-site/dist/public

# مستوى الـ logs (اختياري)
# LOG_LEVEL=info
# LOG_PRETTY=false
